{
  // Shopify Liquid
  "files.associations": {
    "*.html": "liquid"
  },
  // Disable vscode built-in stylelint
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,
  // Run tasks in macOS
  "terminal.integrated.profiles.osx": {
    "zsh": { "path": "/bin/zsh", "args": ["-l", "-i"] }
  },
  // 忽略一些文件夹以便专注于撰写内容
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    ".devcontainer": true,
    ".github": true,
    ".editorconfig": true,
    ".nojekyll": true,
    "Gemfile": true,
    "LICENSE": true,


  }
}
